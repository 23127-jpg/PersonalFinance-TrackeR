PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/finance_tracker?retryWrites=true&w=majority
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=30d

# SMTP Configuration for Nodemailer (Optional, alerts fall back to logs if missing)
EMAIL_SERVICE=gmail
EMAIL_USER=your_gmail_username@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=noreply@financetracker.com
